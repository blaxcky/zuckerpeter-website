---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-copy">&copy; {year} Zuckerpeter · Backen mit Leidenschaft</p>
  </div>
</footer>

<style>
  .footer {
    padding: 1.5rem 1rem 0;
    color: var(--color-text-muted);
  }

  .footer-inner {
    text-align: center;
  }

  .footer-copy {
    font-size: 0.82rem;
  }

  @media (min-width: 780px) {
    .footer {
      padding: 2.25rem 3rem 0;
    }
  }
</style>
