---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src={`${base}logo.png`} alt="Zuckerpeter" width="48" height="48" class="footer-logo" />
      <span class="footer-name">Zuckerpeter</span>
    </div>
    <div class="footer-divider"></div>
    <p class="footer-copy">
      &copy; {year} Zuckerpeter — Backen mit Leidenschaft
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-lg) var(--space-md);
    background: var(--color-text);
    color: var(--color-bg);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .footer-logo {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    opacity: 0.9;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 400;
    font-style: italic;
    opacity: 0.9;
  }

  .footer-divider {
    width: 3rem;
    height: 1px;
    background: rgba(251, 245, 235, 0.2);
  }

  .footer-copy {
    font-size: 0.8rem;
    font-weight: 300;
    opacity: 0.5;
    letter-spacing: 0.03em;
  }
</style>
