---
const base = import.meta.env.BASE_URL;
---

<section class="hero" id="hero">
  <div
    class="hero-media animate-on-scroll"
    style={`background-image: linear-gradient(180deg, rgba(54, 31, 18, 0.08), rgba(54, 31, 18, 0.12)), url('${base}reference-website.png')`}
  >
    <div class="hero-media-overlay"></div>
    <img
      class="hero-logo"
      src={`${base}logo.png`}
      alt="Zuckerpeter Logo"
      width="219"
      height="219"
    />
  </div>
  <div class="hero-band animate-on-scroll">
    <h1 class="hero-title">Willkommen bei Zuckerpeter!</h1>
    <p class="hero-subtitle">Hausgemachte Leckereien mit Leidenschaft gebacken.</p>
    <a class="hero-cta" href="#angebot">Jetzt bestellen!</a>
  </div>
</section>

<style>
  .hero {
    margin-bottom: 1rem;
  }

  .hero-media {
    position: relative;
    min-height: 15rem;
    background-size: 118% auto;
    background-position: center top;
    overflow: hidden;
  }

  .hero-media-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 241, 222, 0) 55%, rgba(125, 77, 46, 0.12) 100%);
  }

  .hero-logo {
    position: absolute;
    left: 50%;
    top: 0.15rem;
    width: min(15rem, 72vw);
    height: auto;
    transform: translateX(-50%);
    filter: drop-shadow(0 0.6rem 1rem rgba(71, 40, 17, 0.25));
  }

  .hero-band {
    background: var(--color-band);
    color: #fff6eb;
    text-align: center;
    padding: 0.85rem 1.1rem 1.15rem;
  }

  .hero-title {
    font-size: clamp(1.75rem, 4.8vw, 2.1rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .hero-subtitle {
    margin-top: 0.35rem;
    font-size: 0.78rem;
    color: rgba(255, 246, 235, 0.88);
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 7.25rem;
    margin-top: 0.85rem;
    padding: 0.45rem 0.9rem;
    border-radius: 0.75rem;
    background: linear-gradient(180deg, var(--color-accent) 0%, #8a511f 100%);
    box-shadow: 0 0.22rem 0 #4a2817, 0 0.55rem 1rem rgba(74, 40, 23, 0.18);
    color: #fff6eb;
    font-size: 0.72rem;
    font-weight: 600;
  }
</style>
