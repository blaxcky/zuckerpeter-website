---
const base = import.meta.env.BASE_URL;
---

<section class="hero" id="hero">
  <div
    class="hero-media animate-on-scroll"
    style={`background-image: linear-gradient(180deg, rgba(54, 31, 18, 0.08), rgba(54, 31, 18, 0.12)), url('${base}reference-website.png')`}
  >
    <div class="hero-media-overlay"></div>
    <img
      class="hero-logo"
      src={`${base}logo.png`}
      alt="Zuckerpeter Logo"
      width="219"
      height="219"
    />
  </div>
  <div class="hero-band animate-on-scroll">
    <h1 class="hero-title">Willkommen bei Zuckerpeter!</h1>
    <p class="hero-subtitle">Hausgemachte Leckereien mit Leidenschaft gebacken.</p>
    <a class="hero-cta" href="#angebot">Jetzt bestellen!</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-bottom: 1.5rem;
  }

  .hero-media {
    position: relative;
    min-height: 18rem;
    background-size: cover;
    background-position: center 10%;
    overflow: hidden;
  }

  .hero-media-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 241, 222, 0) 55%, rgba(125, 77, 46, 0.12) 100%);
  }

  .hero-logo {
    position: absolute;
    left: 50%;
    top: 0.4rem;
    width: min(15.5rem, 72vw);
    height: auto;
    transform: translateX(-50%);
    filter: drop-shadow(0 0.6rem 1rem rgba(71, 40, 17, 0.25));
  }

  .hero-band {
    background: var(--color-band);
    color: #fff6eb;
    text-align: center;
    padding: 1rem 1.2rem 1.3rem;
  }

  .hero-title {
    font-size: clamp(1.8rem, 4.8vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .hero-subtitle {
    margin-top: 0.35rem;
    font-size: 0.88rem;
    color: rgba(255, 246, 235, 0.88);
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 8rem;
    margin-top: 0.85rem;
    padding: 0.55rem 1rem;
    border-radius: 0.85rem;
    background: linear-gradient(180deg, var(--color-accent) 0%, #8a511f 100%);
    box-shadow: 0 0.22rem 0 #4a2817, 0 0.55rem 1rem rgba(74, 40, 23, 0.18);
    color: #fff6eb;
    font-size: 0.8rem;
    font-weight: 600;
  }

  @media (min-width: 780px) {
    .hero {
      padding-bottom: 3rem;
    }

    .hero-media {
      min-height: 34rem;
      border-radius: 1.5rem 1.5rem 0 0;
      background-position: center 16%;
    }

    .hero-logo {
      top: 1rem;
      width: min(23rem, 34vw);
    }

    .hero-band {
      position: relative;
      width: min(42rem, calc(100% - 6rem));
      margin: -3rem auto 0;
      border-radius: 1.4rem;
      padding: 1.65rem 2rem 1.8rem;
      box-shadow: 0 1.5rem 3rem rgba(74, 40, 23, 0.22);
    }

    .hero-title {
      font-size: clamp(2.75rem, 4vw, 3.85rem);
    }

    .hero-subtitle {
      font-size: 1rem;
    }

    .hero-cta {
      min-width: 10.5rem;
      padding: 0.75rem 1.2rem;
      font-size: 0.92rem;
    }
  }
</style>
