<section class="features">
  <div class="features-grid paper-panel">
    <div class="feature-card">
      <div class="feature-icon-wrap">
        <svg viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="feature-svg" aria-hidden="true">
          <rect x="15" y="30" rx="4" ry="4" width="40" height="28" fill="#f0d48a" stroke="#c8a84e" stroke-width="1.5"/>
          <rect x="20" y="35" rx="2" ry="2" width="12" height="18" fill="#f5e0a0" opacity="0.6"/>
          <path d="M58 36 Q65 30 68 38 Q71 46 65 44" fill="#f0d48a" stroke="#c8a84e" stroke-width="1"/>
          <rect x="25" y="15" rx="5" ry="5" width="55" height="10" fill="#d4a574" stroke="#a07040" stroke-width="1" transform="rotate(-8 52 20)"/>
          <rect x="20" y="16" rx="3" ry="3" width="10" height="8" fill="#b08050" transform="rotate(-8 25 20)"/>
          <rect x="75" y="12" rx="3" ry="3" width="10" height="8" fill="#b08050" transform="rotate(-8 80 16)"/>
          <path d="M78 50 Q80 46 84 48 Q88 46 90 50 Q88 56 84 60 Q80 56 78 50Z" fill="#c0392b" opacity="0.4"/>
        </svg>
      </div>
      <h3>Hausgemacht</h3>
      <p>Mit Liebe von Hand gemacht.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon-wrap">
        <svg viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="feature-svg" aria-hidden="true">
          <path d="M30 25 Q30 18 40 15 L60 15 Q70 18 70 25 L72 65 Q72 70 65 70 L35 70 Q28 70 28 65Z" fill="#f5e6d3" stroke="#b08050" stroke-width="1.5"/>
          <path d="M35 25 Q50 20 65 25" stroke="#b08050" stroke-width="2" fill="none"/>
          <ellipse cx="50" cy="22" rx="4" ry="3" fill="#b08050" opacity="0.5"/>
          <rect x="38" y="38" width="24" height="2" rx="1" fill="#b08050" opacity="0.4"/>
          <rect x="40" y="44" width="20" height="2" rx="1" fill="#b08050" opacity="0.3"/>
          <rect x="42" y="50" width="16" height="2" rx="1" fill="#b08050" opacity="0.3"/>
          <line x1="76" y1="60" x2="82" y2="20" stroke="#c8a84e" stroke-width="1.5"/>
          <ellipse cx="82" cy="22" rx="3" ry="6" fill="#ddc173" transform="rotate(-10 82 22)"/>
          <ellipse cx="80" cy="30" rx="3" ry="5" fill="#ddc173" transform="rotate(10 80 30)"/>
          <ellipse cx="83" cy="36" rx="3" ry="5" fill="#ddc173" transform="rotate(-10 83 36)"/>
        </svg>
      </div>
      <h3>Hochwertige Zutaten</h3>
      <p>Ich verwende nur die besten Zutaten.</p>
    </div>

    <div class="feature-card">
      <div class="feature-icon-wrap">
        <svg viewBox="0 0 100 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="feature-svg" aria-hidden="true">
          <ellipse cx="50" cy="52" rx="28" ry="20" fill="#d4a574" stroke="#b08050" stroke-width="1.5"/>
          <circle cx="40" cy="48" r="3" fill="#b08050" opacity="0.4"/>
          <circle cx="55" cy="44" r="2.5" fill="#b08050" opacity="0.4"/>
          <circle cx="48" cy="58" r="2" fill="#b08050" opacity="0.3"/>
          <circle cx="60" cy="55" r="2.5" fill="#b08050" opacity="0.4"/>
          <circle cx="38" cy="55" r="2" fill="#b08050" opacity="0.3"/>
          <path d="M42 30 Q39 22 42 15" stroke="#c8a84e" stroke-width="1.5" fill="none" opacity="0.4" stroke-linecap="round" />
          <path d="M52 28 Q49 20 52 12" stroke="#c8a84e" stroke-width="1.5" fill="none" opacity="0.35" stroke-linecap="round" />
          <path d="M62 30 Q59 23 62 16" stroke="#c8a84e" stroke-width="1.2" fill="none" opacity="0.3" stroke-linecap="round" />
        </svg>
      </div>
      <h3>Immer Frisch</h3>
      <p>Gebäck, das immer frisch und lecker ist.</p>
    </div>
  </div>
</section>

<style>
  .features {
    padding: 0.4rem 1.5rem 2.2rem;
  }

  .features-grid {
    max-width: 1020px;
    margin: 0 auto;
    border-radius: 1.8rem;
    padding: 1.25rem 1rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0;
  }

  .feature-card {
    text-align: center;
    padding: 1rem 1.4rem 1.15rem;
  }

  .feature-card:not(:last-child) {
    border-right: 1px solid rgba(122, 74, 29, 0.16);
  }

  .feature-icon-wrap {
    width: 5.4rem;
    height: 4.4rem;
    margin: 0 auto 0.7rem;
  }

  .feature-svg {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 3px 6px rgba(86, 46, 19, 0.1));
  }

  h3 {
    font-family: var(--font-heading);
    font-size: 1.38rem;
    color: var(--color-brown-dark);
    margin-bottom: 0.2rem;
  }

  p {
    color: var(--color-text-light);
    font-size: 0.97rem;
  }

  @media (max-width: 720px) {
    .features-grid {
      grid-template-columns: 1fr;
      padding: 0.6rem 0.8rem;
      border-radius: 1.35rem;
    }

    .feature-card:not(:last-child) {
      border-right: 0;
      border-bottom: 1px solid rgba(122, 74, 29, 0.16);
    }
  }
</style>
