---
const base = import.meta.env.BASE_URL;
---

<section class="angebot" id="angebot" style={`--reference-image: url(${base}reference-website.png)`}>
  <div class="angebot-inner">
    <h2 class="section-title">Unser Angebot</h2>
    <p class="section-subtitle">Entdecke meine Auswahl an köstlichen, hausgemachten Leckereien.</p>

    <div class="angebot-grid">
      <article class="angebot-card">
        <div class="angebot-image paper-panel">
          <div class="angebot-shot kekse"></div>
        </div>
        <div class="angebot-label">
          <span class="label-wing left"></span>
          <span class="label-text">Kekse</span>
          <span class="label-wing right"></span>
        </div>
      </article>

      <article class="angebot-card">
        <div class="angebot-image paper-panel">
          <div class="angebot-shot gebaeck"></div>
        </div>
        <div class="angebot-label">
          <span class="label-wing left"></span>
          <span class="label-text">Gebäck</span>
          <span class="label-wing right"></span>
        </div>
      </article>

      <article class="angebot-card">
        <div class="angebot-image paper-panel">
          <div class="angebot-shot kuchen"></div>
        </div>
        <div class="angebot-label">
          <span class="label-wing left"></span>
          <span class="label-text">Kuchen</span>
          <span class="label-wing right"></span>
        </div>
      </article>

      <article class="angebot-card">
        <div class="angebot-image paper-panel">
          <div class="angebot-shot torten"></div>
        </div>
        <div class="angebot-label">
          <span class="label-wing left"></span>
          <span class="label-text">Torten</span>
          <span class="label-wing right"></span>
        </div>
      </article>
    </div>

    <div class="angebot-cta">
      <a href="#kontakt" class="btn-ornate">Zur Galerie</a>
    </div>
  </div>
</section>

<style>
  .angebot {
    padding: 1.3rem 1.5rem 0;
  }

  .angebot-inner {
    max-width: 1060px;
    margin: 0 auto;
    text-align: center;
  }

  .angebot-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1.8rem;
  }

  .angebot-card {
    position: relative;
  }

  .angebot-image {
    border-radius: 0.45rem;
    padding: 0.4rem;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .angebot-card:hover .angebot-image {
    transform: translateY(-4px);
    box-shadow: var(--shadow-deep);
  }

  .angebot-shot {
    aspect-ratio: 1.04;
    border-radius: 0.25rem;
    background-image: var(--reference-image);
    background-size: 33rem auto;
    background-repeat: no-repeat;
    box-shadow: inset 0 0 0 1px rgba(120, 71, 29, 0.12);
  }

  .angebot-shot::after {
    content: '';
    display: block;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(180deg, rgba(255, 237, 208, 0.12), transparent 35%),
      linear-gradient(180deg, transparent 50%, rgba(61, 26, 8, 0.12));
  }

  .kekse {
    background-position: -1.8rem -39.2rem;
  }

  .gebaeck {
    background-position: -10.4rem -39.2rem;
  }

  .kuchen {
    background-position: -18.8rem -39.2rem;
  }

  .torten {
    background-position: -27.2rem -39.2rem;
  }

  .angebot-label {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 82%;
    margin: -0.8rem auto 0;
    z-index: 1;
  }

  .label-text {
    display: inline-block;
    padding: 0.58rem 1.3rem;
    background: linear-gradient(180deg, #8f5317 0%, #6b350b 60%, #4a2108 100%);
    color: #fbe6b6;
    font-family: var(--font-heading);
    font-size: 1.35rem;
    line-height: 1;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 212, 140, 0.35);
    box-shadow: 0 10px 15px rgba(61, 26, 8, 0.22);
  }

  .label-wing {
    width: 1rem;
    height: 2.05rem;
    flex-shrink: 0;
    background: linear-gradient(180deg, #8f5317, #4a2108);
  }

  .label-wing.left {
    clip-path: polygon(0% 15%, 100% 0%, 100% 100%, 0% 85%);
  }

  .label-wing.right {
    clip-path: polygon(0% 0%, 100% 15%, 100% 85%, 0% 100%);
  }

  .angebot-cta {
    margin-top: 2rem;
    padding-bottom: 1rem;
  }

  @media (max-width: 960px) {
    .angebot-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.2rem;
    }
  }

  @media (max-width: 520px) {
    .angebot {
      padding-inline: 1rem;
    }

    .angebot-grid {
      gap: 0.9rem;
    }

    .label-text {
      font-size: 1.1rem;
      padding-inline: 1rem;
    }
  }
</style>
