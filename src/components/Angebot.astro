---
const base = import.meta.env.BASE_URL;

const products = [
  { name: 'Kekse', position: '4% 100%' },
  { name: 'Gebäck', position: '35% 100%' },
  { name: 'Kuchen', position: '66% 100%' },
  { name: 'Torten', position: '97% 100%' },
];
---

<section class="angebot" id="angebot">
  <div class="angebot-inner">
    <div class="angebot-header animate-on-scroll">
      <h2 class="angebot-heading">Unser Angebot</h2>
      <p class="angebot-intro">
        Entdecke meine Auswahl an köstlichen, hausgemachten Leckereien.
      </p>
    </div>
    <div class="angebot-grid">
      {products.map((product) => (
        <article class="product-card animate-on-scroll">
          <div class="product-image-wrap">
            <div
              class="product-image"
              style={`background-image: url('${base}reference-website.png'); --product-position: ${product.position};`}
            ></div>
          </div>
          <div class="product-label">{product.name}</div>
        </article>
      ))}
    </div>
    <div class="angebot-cta-wrap animate-on-scroll">
      <a class="angebot-cta" href="#hero">Zur Galerie</a>
    </div>
  </div>
</section>

<style>
  .angebot {
    padding: 1.1rem 1rem 0;
  }

  .angebot-header {
    text-align: center;
    margin-bottom: 0.85rem;
  }

  .angebot-heading {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
  }

  .angebot-intro {
    margin-top: 0.35rem;
    font-size: 0.52rem;
    color: var(--color-text-muted);
    line-height: 1.45;
  }

  .angebot-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .product-card {
    background: var(--color-card);
    padding: 0.25rem 0.25rem 0.18rem;
    border-radius: 0.32rem;
    box-shadow: inset 0 0 0 1px rgba(125, 77, 46, 0.05);
  }

  .product-image-wrap {
    aspect-ratio: 1.85 / 1;
    overflow: hidden;
    border-radius: 0.2rem;
    background: var(--color-bg-warm);
  }

  .product-image {
    width: 100%;
    height: 100%;
    background-size: 32rem auto;
    background-repeat: no-repeat;
    background-position: var(--product-position);
  }

  .product-label {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 1.35rem;
    margin: 0.16rem auto 0;
    width: calc(100% - 1rem);
    border-radius: 0.25rem;
    background: linear-gradient(180deg, var(--color-accent) 0%, #8a511f 100%);
    box-shadow: 0 0.1rem 0 #4a2817;
    color: #fff4e6;
    font-family: var(--font-display);
    font-size: 0.83rem;
    font-weight: 700;
  }

  .angebot-cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: 0.7rem;
  }

  .angebot-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 6.6rem;
    padding: 0.42rem 0.85rem;
    border-radius: 0.75rem;
    background: linear-gradient(180deg, var(--color-accent) 0%, #8a511f 100%);
    box-shadow: 0 0.2rem 0 #4a2817, 0 0.45rem 0.8rem rgba(74, 40, 23, 0.14);
    color: #fff4e6;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
  }
</style>
