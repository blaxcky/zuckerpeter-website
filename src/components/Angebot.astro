---
const base = import.meta.env.BASE_URL;

const products = [
  {
    name: 'Kekse',
    description: ['Knusprig, buttrig und', 'perfekt zu Kaffee und Tee.'],
    position: '10% 72%',
  },
  {
    name: 'Gebäck',
    description: ['Feine Stücke zum', 'Genießen und Teilen.'],
    position: '38% 72%',
  },
  {
    name: 'Kuchen',
    description: ['Saftige Kuchen von', 'klassisch bis kreativ.'],
    position: '64% 72%',
  },
  {
    name: 'Torten',
    description: ['Liebevoll dekoriert und', 'unglaublich lecker.'],
    position: '88% 72%',
  },
];
---

<section class="angebot" id="angebot">
  <div class="angebot-inner">
    <div class="angebot-header animate-on-scroll">
      <span class="angebot-label">Sortiment</span>
      <h2 class="angebot-heading">Unser Angebot</h2>
      <p class="angebot-intro">
        Von knusprigen Keksen bis hin zu kunstvollen Torten, bei uns findet
        jeder seinen Liebling.
      </p>
    </div>
    <div class="angebot-grid">
      {products.map((product, i) => (
        <article class="product-card animate-on-scroll" style={`transition-delay: ${(i + 1) / 10}s`}>
          <div class="product-image-wrap">
            <div
              class="product-image"
              style={`background-image: url('${base}reference-website.png'); background-position: ${product.position};`}
            ></div>
          </div>
          <div class="product-info">
            <h3 class="product-name">{product.name}</h3>
            {product.description.map((line) => (
              <p class="product-desc">{line}</p>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .angebot {
    padding: var(--space-2xl) var(--space-md);
    background: var(--color-bg);
  }

  .angebot-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .angebot-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .angebot-label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .angebot-heading {
    font-size: clamp(2.2rem, 4vw, 3.75rem);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .angebot-intro {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: 38rem;
    margin: 0 auto;
  }

  .angebot-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
  }

  .product-card {
    background: var(--color-card);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 1rem 3rem rgba(44, 24, 16, 0.06);
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(44, 24, 16, 0.1);
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-image-wrap {
    aspect-ratio: 16 / 7;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .product-image {
    width: 100%;
    height: 100%;
    background-size: 60rem auto;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-info {
    padding: 1.5rem 1.5rem 1.75rem;
  }

  .product-name {
    font-size: 1.9rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.45rem;
  }

  .product-desc {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .product-desc + .product-desc {
    margin-top: 0.05rem;
  }

  @media (max-width: 768px) {
    .angebot-grid {
      grid-template-columns: 1fr;
      max-width: 24rem;
      margin: 0 auto;
    }

    .product-name {
      font-size: 1.65rem;
    }
  }
</style>
