---
const categories = [
  { name: 'Kekse', emoji: '🍪', color: '#d4a574' },
  { name: 'Gebäck', emoji: '🥐', color: '#c89b6b' },
  { name: 'Kuchen', emoji: '🍰', color: '#b8860b' },
  { name: 'Torten', emoji: '🎂', color: '#a0522d' },
];
---

<section class="angebot" id="angebot">
  <div class="angebot-inner">
    <h2>Unser Angebot</h2>
    <p class="angebot-subtitle">Entdecke meine Auswahl an köstlichen, hausgemachten Leckereien.</p>
    <div class="angebot-grid">
      {categories.map((cat) => (
        <div class="angebot-card">
          <div class="angebot-img" style={`background: linear-gradient(135deg, ${cat.color}, ${cat.color}dd);`}>
            <span class="angebot-emoji">{cat.emoji}</span>
          </div>
          <div class="angebot-label">
            <span>{cat.name}</span>
          </div>
        </div>
      ))}
    </div>
    <div class="angebot-cta">
      <a href="#kontakt" class="btn">Zur Galerie</a>
    </div>
  </div>
</section>

<style>
  .angebot {
    padding: 4rem 1.5rem;
    background: var(--color-bg-alt);
    text-align: center;
  }

  .angebot-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    color: var(--color-brown-dark);
    margin-bottom: 0.5rem;
  }

  .angebot-subtitle {
    color: var(--color-text-light);
    font-size: 1.05rem;
    margin-bottom: 2.5rem;
  }

  .angebot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .angebot-card {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(92, 61, 46, 0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
  }

  .angebot-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(92, 61, 46, 0.25);
  }

  .angebot-img {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .angebot-emoji {
    font-size: 4rem;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.2));
  }

  .angebot-label {
    padding: 0.75rem;
    background: linear-gradient(135deg, var(--color-brown) 0%, var(--color-brown-dark) 100%);
  }

  .angebot-label span {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-gold);
  }

  .btn {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    background: linear-gradient(135deg, var(--color-brown) 0%, var(--color-brown-dark) 100%);
    color: var(--color-gold);
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    border: 2px solid var(--color-gold);
    border-radius: 6px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .btn:hover {
    background: linear-gradient(135deg, var(--color-accent-dark) 0%, var(--color-brown) 100%);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(139, 105, 20, 0.4);
  }

  .angebot-cta {
    margin-top: 1rem;
  }
</style>
