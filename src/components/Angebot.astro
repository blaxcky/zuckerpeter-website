---
const base = import.meta.env.BASE_URL;

const products = [
  {
    name: 'Kekse',
    description: 'Knusprig, buttrig und unwiderstehlich — unsere Kekse sind der perfekte Begleiter zu Kaffee und Tee.',
    position: '-2rem -42.35rem',
  },
  {
    name: 'Gebäck',
    description: 'Feine Gebäckstücke für besondere Anlässe oder einfach so — zum Genießen und Teilen.',
    position: '-15.3rem -42.35rem',
  },
  {
    name: 'Kuchen',
    description: 'Saftige Kuchen in vielen Variationen — von klassisch bis kreativ, immer ein Genuss.',
    position: '-28.6rem -42.35rem',
  },
  {
    name: 'Torten',
    description: 'Unsere Torten sind echte Hingucker — liebevoll dekoriert und unglaublich lecker.',
    position: '-41.85rem -42.35rem',
  },
];
---

<section class="angebot" id="angebot">
  <div class="angebot-inner">
    <div class="angebot-header animate-on-scroll">
      <span class="angebot-label">Sortiment</span>
      <h2 class="angebot-heading">Unser <em>Angebot</em></h2>
      <p class="angebot-intro">
        Von knusprigen Keksen bis hin zu kunstvollen Torten — bei uns findet jeder seinen Liebling.
      </p>
    </div>
    <div class="angebot-grid">
      {products.map((product, i) => (
        <article class="product-card animate-on-scroll" style={`transition-delay: ${(i + 1) / 10}s`}>
          <div class="product-image-wrap">
            <div
              class="product-image"
              style={`background-image: url('${base}reference-website.png'); background-position: ${product.position};`}
            ></div>
          </div>
          <div class="product-info">
            <h3 class="product-name">{product.name}</h3>
            <p class="product-desc">{product.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .angebot {
    padding: var(--space-2xl) var(--space-md);
    background: var(--color-bg);
  }

  .angebot-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .angebot-header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .angebot-label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .angebot-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .angebot-heading em {
    font-style: italic;
    color: var(--color-accent);
  }

  .angebot-intro {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
  }

  .angebot-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .product-card {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(44, 24, 16, 0.1);
  }

  .product-card:hover .product-image {
    transform: scale(1.05);
  }

  .product-image-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .product-image {
    width: 100%;
    height: 100%;
    background-size: 56.2rem auto;
    background-repeat: no-repeat;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-info {
    padding: var(--space-md);
  }

  .product-name {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .product-desc {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .angebot-grid {
      grid-template-columns: 1fr;
      max-width: 28rem;
      margin: 0 auto;
    }
  }
</style>
