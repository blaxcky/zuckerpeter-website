---
const base = import.meta.env.BASE_URL;
---

<section class="about" id="about">
  <div class="about-inner animate-on-scroll">
    <div class="about-text-col">
      <h2 class="about-heading">Über Zuckerpeter</h2>
      <p class="about-copy">
        Hallo! Ich bin Zuckerpeter, leidenschaftlicher Hobbybäcker mit einer
        Liebe für hausgemachte Leckereien.
      </p>
      <p class="about-copy">
        Mit viel Herz und Hingabe bereite ich in meiner gemütlichen Küche
        köstliche Kekse und Kuchen zu.
      </p>
      <p class="about-copy">
        Bei mir steht Qualität und Geschmack an erster Stelle.
      </p>
      <a class="about-button" href="#angebot">Mehr erfahren</a>
    </div>
    <div class="about-visual">
      <div class="about-oval"></div>
      <img
        class="about-logo"
        src={`${base}logo.png`}
        alt="Zuckerpeter Signet"
        width="219"
        height="219"
      />
    </div>
  </div>
</section>

<style>
  .about {
    padding: 1.75rem 1.1rem 0.6rem;
  }

  .about-inner {
    display: grid;
    gap: 1rem;
    align-items: center;
  }

  .about-heading {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
    margin-bottom: 0.85rem;
  }

  .about-copy {
    max-width: 33rem;
    margin-top: 0.6rem;
    font-size: 0.92rem;
    line-height: 1.72;
    color: var(--color-text-muted);
  }

  .about-copy:first-of-type {
    margin-top: 0;
  }

  .about-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 8rem;
    margin-top: 1rem;
    padding: 0.65rem 1rem;
    border-radius: 0.75rem;
    background: linear-gradient(180deg, var(--color-accent) 0%, #8a511f 100%);
    box-shadow: 0 0.22rem 0 #4a2817, 0 0.5rem 0.95rem rgba(74, 40, 23, 0.16);
    color: #fff6eb;
    font-size: 0.84rem;
    font-weight: 600;
  }

  .about-visual {
    position: relative;
    width: min(100%, 20rem);
    height: 13rem;
    justify-self: center;
  }

  .about-oval {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: #d9b084;
  }

  .about-logo {
    position: absolute;
    inset: 0;
    width: 15.5rem;
    height: 15.5rem;
    margin: auto;
    transform: translateY(-0.2rem);
    object-fit: contain;
  }

  @media (min-width: 780px) {
    .about {
      padding: 3rem 3rem 1.2rem;
    }

    .about-inner {
      grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 24rem);
      gap: 2rem;
    }

    .about-heading {
      font-size: clamp(2.6rem, 4vw, 3.4rem);
    }

    .about-copy {
      font-size: 1rem;
      max-width: 31rem;
    }

    .about-visual {
      width: 24rem;
      height: 15rem;
    }

    .about-logo {
      width: 17.5rem;
      height: 17.5rem;
    }
  }
</style>
