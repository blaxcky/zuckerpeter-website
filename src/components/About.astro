---
const base = import.meta.env.BASE_URL;
---

<section class="about" id="about">
  <div class="about-inner">
    <div class="about-image-col animate-on-scroll">
      <div class="about-image-frame">
        <div class="about-image"
          style={`background-image: url('${base}reference-website.png')`}>
        </div>
        <div class="about-image-accent"></div>
      </div>
    </div>
    <div class="about-text-col">
      <span class="about-label animate-on-scroll">Über uns</span>
      <h2 class="about-heading animate-on-scroll">
        Wer steckt hinter<br/><em>Zuckerpeter?</em>
      </h2>
      <p class="about-body animate-on-scroll">
        Hinter Zuckerpeter steckt Peter — ein leidenschaftlicher Hobbybäcker,
        der seine Liebe zum Backen zum kleinen Nebenprojekt gemacht hat. Was als
        Hobby begann, ist heute eine Herzensangelegenheit: Jedes Stück wird mit
        Sorgfalt, hochwertigen Zutaten und viel Liebe von Hand gefertigt.
      </p>
      <p class="about-body animate-on-scroll">
        Bei Zuckerpeter gibt es keine Massenproduktion — nur ehrliches,
        handgemachtes Gebäck, das von Herzen kommt.
      </p>
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--space-2xl) var(--space-md);
    background: var(--color-bg);
  }

  .about-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .about-image-col {
    position: relative;
  }

  .about-image-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    overflow: hidden;
  }

  .about-image {
    width: 100%;
    height: 100%;
    background-size: 56.2rem auto;
    background-position: -2.4rem -26.9rem;
    background-repeat: no-repeat;
  }

  .about-image-accent {
    position: absolute;
    inset: 0;
    border: 2px solid var(--color-gold);
    border-radius: var(--radius);
    transform: translate(0.75rem, 0.75rem);
    pointer-events: none;
    z-index: -1;
  }

  .about-text-col {
    padding: var(--space-md) 0;
  }

  .about-label {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .about-heading {
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    line-height: 1.2;
  }

  .about-heading em {
    font-style: italic;
    color: var(--color-accent);
  }

  .about-body {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.85;
    margin-bottom: var(--space-sm);
  }

  .about-body:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .about-inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .about-image-frame {
      aspect-ratio: 3 / 4;
      max-width: 24rem;
      margin: 0 auto;
    }
  }
</style>
