---
const base = import.meta.env.BASE_URL;
---

<section class="about" id="about">
  <div class="about-inner animate-on-scroll">
    <div class="about-text-col">
      <h2 class="about-heading">Über Zuckerpeter</h2>
      <p class="about-copy">Hallo! Ich bin Zuckerpeter, leidenschaftlicher</p>
      <p class="about-copy">Hobbybäcker mit einer Liebe für</p>
      <p class="about-copy">hausgemachte Leckereien.</p>
      <p class="about-copy about-copy-gap">Mit viel Herz und Hingabe bereite ich</p>
      <p class="about-copy">in meiner gemütlichen Küche köstliche</p>
      <p class="about-copy">Kekse und Kuchen zu.</p>
      <p class="about-copy about-copy-gap">Bei mir steht Qualität und Geschmack</p>
      <p class="about-copy">an erster Stelle.</p>
      <a class="about-button" href="#angebot">Mehr erfahren</a>
    </div>
    <div class="about-visual">
      <div class="about-oval"></div>
      <img
        class="about-logo"
        src={`${base}logo.png`}
        alt="Zuckerpeter Signet"
        width="219"
        height="219"
      />
    </div>
  </div>
</section>

<style>
  .about {
    padding: 1.35rem 1rem 0.35rem;
  }

  .about-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: center;
  }

  .about-heading {
    font-size: 1.95rem;
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.05;
    margin-bottom: 0.8rem;
  }

  .about-copy {
    font-size: 0.52rem;
    line-height: 1.48;
    color: var(--color-text-muted);
    text-wrap: balance;
  }

  .about-copy-gap {
    margin-top: 0.55rem;
  }

  .about-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 6.6rem;
    margin-top: 0.85rem;
    padding: 0.45rem 0.75rem;
    border-radius: 0.75rem;
    background: linear-gradient(180deg, var(--color-accent) 0%, #8a511f 100%);
    box-shadow: 0 0.22rem 0 #4a2817, 0 0.5rem 0.95rem rgba(74, 40, 23, 0.16);
    color: #fff6eb;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .about-visual {
    position: relative;
    width: 12rem;
    height: 8.2rem;
  }

  .about-oval {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: #d9b084;
  }

  .about-logo {
    position: absolute;
    inset: 0;
    width: 10rem;
    height: 10rem;
    margin: auto;
    transform: translateY(-0.15rem);
    object-fit: contain;
  }
</style>
